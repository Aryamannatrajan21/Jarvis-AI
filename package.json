{
  "name": "jarvis-ai",
  "private": true,
  "version": "0.1.0-alpha",
  "description": "An open-source framework for building model-agnostic collaborative AI agents.",
  "workspaces": [
    "packages/*",
    "providers/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "start:playground": "npm run build && node --env-file=.env examples/playground/dist/index.js",
    "start:chat": "npm run build && node --env-file=.env examples/playground/dist/liveChat.js",
    "start:voice": "npm run build && node --env-file=.env examples/playground/dist/server.js"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "turbo": "^1.12.4",
    "tsx": "^4.7.1"
  }
}
