{
  "name": "jarvis-ai",
  "private": true,
  "version": "0.1.0-alpha",
  "description": "An open-source framework for building model-agnostic collaborative AI agents.",
  "workspaces": [
    "packages/*",
    "providers/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "start:playground": "npm run build && node examples/playground/dist/index.js",
    "start:chat": "npm run build && node examples/playground/dist/liveChat.js",
    "start:voice": "npm run build && node examples/playground/dist/server.js"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^9.39.4",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.7.1",
    "turbo": "^1.12.4",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.60.1"
  },
  "dependencies": {
    "jarvis-ai": "^0.1.0",
    "zod": "^3.25.76"
  }
}
